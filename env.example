# Copy this file to .env.local and add your actual API keys
# Get your API keys from:
# Groq: https://console.groq.com/
# Claude: https://console.anthropic.com/
# Clerk: https://dashboard.clerk.com/last-active?path=api-keys
# Supabase: https://supabase.com/dashboard
# Stripe: https://dashboard.stripe.com/apikeys

# Required for relaxed mode (Groq)
GROQ_API_KEY=your_groq_api_key_here

# Required for strict mode (Claude Haiku)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Clerk Authentication (get from https://dashboard.clerk.com/last-active?path=api-keys)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Supabase (add these after creating Supabase project)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key # Required for workflow execution (get from Supabase dashboard > Settings > API)

# Stripe (get from Stripe dashboard)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_STRIPE_PRICE_ID=price_... # Legacy Pro tier price ID (for backward compatibility)

# Stripe Price IDs for Workflows
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_... # Pro subscription price ID
NEXT_PUBLIC_STRIPE_PREMIUM_PRICE_ID=price_... # Premium subscription price ID
NEXT_PUBLIC_STRIPE_CREDITS_100_PRICE_ID=price_... # 100 credits one-time payment
NEXT_PUBLIC_STRIPE_CREDITS_500_PRICE_ID=price_... # 500 credits one-time payment
NEXT_PUBLIC_STRIPE_CREDITS_1500_PRICE_ID=price_... # 1500 credits one-time payment

# Developer user IDs that get free Pro access (comma-separated)
# Get your Clerk user ID from: https://dashboard.clerk.com/users
DEV_USER_IDS=user_xxx,user_yyy

# Site URL (OAuth redirect_uri base, Stripe success/cancel URLs). No trailing slash.
# Production: https://zunno.app — must match Instagram/Meta app redirect URI allowlist exactly.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Instagram / Meta — Basic Display OAuth (https://developers.facebook.com/)
# Register redirect URI: {NEXT_PUBLIC_APP_URL}/api/auth/instagram/callback
NEXT_PUBLIC_META_APP_ID=your-meta-instagram-app-id
META_APP_SECRET=your-meta-app-secret

# LinkedIn OAuth (https://www.linkedin.com/developers/)
# Register redirect URI: {NEXT_PUBLIC_APP_URL}/api/auth/linkedin/callback
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret

# X (Twitter) OAuth 1.0a user context — https://developer.x.com/en/docs/authentication/oauth-1-0a
# Register callback URL: {NEXT_PUBLIC_APP_URL}/api/auth/twitter/callback
TWITTER_CONSUMER_KEY=your-twitter-consumer-key
TWITTER_CONSUMER_SECRET=your-twitter-consumer-secret